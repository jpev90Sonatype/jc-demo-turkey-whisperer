{
  "name": "frontend",
  "version": "20.1.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production && npm run sbom",
    "sbom": "cyclonedx-esbuild --output-reproducible --output-file dist/bom/bom.json dist/frontend/stats.json",
    "bundle-visualizer": "node --experimental-strip-types filter-bundle-stats-for-diagram.mts && npx esbuild-visualizer --metadata dist/frontend/stats-filtered.json --filename dist/frontend/bundle-report.html",
    "bundle-visualizer:full": "npx esbuild-visualizer --metadata dist/frontend/stats.json --filename dist/frontend/bundle-report.html",
    "test": "ng test",
    "test:coverage": "ng test --configuration=coverage --watch=false",
    "test:watch": "ng test --watch --reporters=default",
    "test:verbose": "ng test --reporters=verbose",
    "lint": "ng lint",
    "lint:scss": "npx stylelint \"**/*.scss\"",
    "lint:fix": "ng lint --fix && npx stylelint \"**/*.scss\" --fix"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/build": "^21.2.1",
    "@angular/cdk": "^21.2.1",
    "@angular/cli": "^22.1.0-next.4",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^22.1.0-next.6",
    "@angular/compiler-cli": "^22.1.0-next.6",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/material": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/merge": "^6.12.2",
    "@cyclonedx/cyclonedx-esbuild": "^1.4.2",
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-brands-svg-icons": "^7.3.1",
    "@fortawesome/free-regular-svg-icons": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "@wagmi/core": "^3.6.3",
    "canvas-confetti": "^1.9.4",
    "codemirror": "^6.0.2",
    "cookieconsent": "^3.1.1",
    "ethers": "^6.17.0",
    "flag-icons": "^7.5.0",
    "font-mfizz": "^2.4.1",
    "jwt-decode": "^4.0.0",
    "lodash-es": "^4.18.1",
    "material-icons": "^1.13.14",
    "ng-gallery": "^13.0.0-next.0",
    "ng-qrcode": "^21.0.0",
    "ng2-file-upload": "^10.0.0",
    "ngx-window-token": "^7.0.0",
    "ngy-cookie": "^6.0.1000",
    "postcss": "^8.4.21",
    "rxjs": "7.8.2",
    "sass": "^1.101.6",
    "snarkdown": "^1.2.2",
    "socket.io-client": "^4.8.3",
    "solidity-browser-compiler": "^1.1.0",
    "tslib": "^2.8.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/language-service": "^22.1.0-next.6",
    "@eslint/js": "9.33.0",
    "@types/express-serve-static-core": "^5.1.2",
    "@types/jwt-decode": "^3.1.0",
    "@types/node": "^26.1.1",
    "@types/socket.io-client": "^3.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "angular-eslint": "^22.1.0",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^9.33.0",
    "jsdom": "^29.1.1",
    "stylelint": "^17.14.1",
    "stylelint-config-sass-guidelines": "^13.0.0",
    "stylelint-scss": "^7.2.0",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "lru-cache@^11": "~11.2.7"
  }
}
